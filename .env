SERVER_PORT=8080

# DEBE ser exactamente el mismo valor que JWT_SECRET del Auth Backend
# (si no coinciden, el Gateway rechaza TODOS los tokens con "invalid_token")
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-al-menos-32-chars
# URLs internas de los microservicios (a donde el Gateway hace proxy)
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
